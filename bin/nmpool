#!/usr/bin/env python3
"""nmpool — pool git-worktree node_modules directories.

Worktrees need a REAL node_modules (not a symlink — Next/Turbopack rejects
out-of-root node_modules symlinks). Re-installing 1-2 GB per worktree is
wasteful, so this tool keeps a global pool of node_modules dirs keyed by
lockfile hash and moves them between the pool and worktrees with an O(1)
atomic rename (when pool + worktree share a volume).

The pool is a single global directory (default $XDG_CACHE_HOME/nmpool), bounded
by a total-bytes budget. Both are configurable via env vars or
$XDG_CONFIG_HOME/nmpool/config.json.

PURE PYTHON 3 STDLIB. This tool *creates* node_modules, so it must never
depend on node_modules or any pip package.
"""

import argparse
import errno
import glob
import hashlib
import json
import os
import secrets
import shutil
import subprocess
import sys
import time

SENTINEL = ".nmpool-hash"
DEFAULT_MAX_BYTES = 25 * 1024 ** 3  # 25 GiB

# Lockfile -> (install argv). Priority order matters: first match wins.
LOCKFILES = [
    ("bun.lock", ["bun", "install", "--frozen-lockfile"]),
    ("bun.lockb", ["bun", "install", "--frozen-lockfile"]),
    ("pnpm-lock.yaml", ["pnpm", "install", "--frozen-lockfile"]),
    ("package-lock.json", ["npm", "ci"]),
    ("yarn.lock", ["yarn", "install", "--immutable"]),
]


def eprint(*a):
    print(*a, file=sys.stderr)


def out(msg):
    print(msg)


# ---------------------------------------------------------------------------
# config — env var > config file > default. Read directly so the tool works
# standalone (no harness injection assumed).
# ---------------------------------------------------------------------------

def _xdg(sub, env):
    base = os.environ.get(env)
    if not base:
        base = os.path.join(os.path.expanduser("~"), sub)
    return base


def _config_path():
    return os.path.join(_xdg(".config", "XDG_CONFIG_HOME"), "nmpool", "config.json")


def _load_config():
    try:
        with open(_config_path()) as f:
            cfg = json.load(f)
        return cfg if isinstance(cfg, dict) else {}
    except (OSError, ValueError):
        return {}


def cache_dir():
    """Global pool location: NMPOOL_CACHE_DIR > config cacheDir > XDG cache."""
    v = os.environ.get("NMPOOL_CACHE_DIR")
    if not v:
        v = _load_config().get("cacheDir")
    if v:
        return os.path.abspath(os.path.expanduser(v))
    return os.path.join(_xdg(".cache", "XDG_CACHE_HOME"), "nmpool")


def max_cache_bytes():
    """Total-bytes budget: NMPOOL_MAX_BYTES > config maxCacheBytes > 25 GiB."""
    v = os.environ.get("NMPOOL_MAX_BYTES")
    if v is not None:
        try:
            return int(v)
        except ValueError:
            eprint("warn: ignoring non-integer NMPOOL_MAX_BYTES=%r" % v)
    cfg = _load_config().get("maxCacheBytes")
    if isinstance(cfg, int):
        return cfg
    return DEFAULT_MAX_BYTES


# ---------------------------------------------------------------------------
# git / lockfile helpers
# ---------------------------------------------------------------------------

def _git(args, cwd):
    res = subprocess.run(["git"] + args, cwd=cwd, capture_output=True, text=True)
    if res.returncode != 0:
        raise RuntimeError(
            "git %s failed: %s" % (" ".join(args), res.stderr.strip())
        )
    return res.stdout.strip()


def worktree_root(path):
    """Top-level of the git worktree enclosing `path`."""
    return os.path.realpath(_git(["rev-parse", "--show-toplevel"], cwd=path))


def detect_lockfile(wt):
    for name, install_cmd in LOCKFILES:
        p = os.path.join(wt, name)
        if os.path.isfile(p):
            return p, install_cmd
    raise RuntimeError(
        "no lockfile found in %s (looked for: %s)"
        % (wt, ", ".join(n for n, _ in LOCKFILES))
    )


def lockfile_hash(lockfile_path):
    with open(lockfile_path, "rb") as f:
        data = f.read()
    return hashlib.sha256(data).hexdigest()[:16]


def read_sentinel(nm_dir):
    p = os.path.join(nm_dir, SENTINEL)
    try:
        with open(p, "r") as f:
            return f.read().strip()
    except OSError:
        return None


def write_sentinel(nm_dir, h):
    with open(os.path.join(nm_dir, SENTINEL), "w") as f:
        f.write(h + "\n")


# ---------------------------------------------------------------------------
# install seam (test-only fake)
# ---------------------------------------------------------------------------

def run_install(wt, install_cmd, h):
    """Run the package manager's frozen install in the worktree.

    Test seam: NMPOOL_FAKE_INSTALL=1 fabricates a tiny node_modules instead of
    invoking a real package manager. Gated so it never affects real use.
    """
    nm = os.path.join(wt, "node_modules")
    if os.environ.get("NMPOOL_FAKE_INSTALL") == "1":
        os.makedirs(nm, exist_ok=True)
        with open(os.path.join(nm, ".fake-install-marker"), "w") as f:
            f.write("fake install for %s\n" % h)
        return
    res = subprocess.run(install_cmd, cwd=wt)
    if res.returncode != 0:
        raise RuntimeError("install failed: %s" % " ".join(install_cmd))


# ---------------------------------------------------------------------------
# pool entry helpers (size is encoded in the entry name)
#   node_modules_<hash>_<slug>_<bytes>
# ---------------------------------------------------------------------------

def _rmtree(path):
    shutil.rmtree(path, ignore_errors=True)


def _dir_size(path):
    """Total bytes of a tree. Never follows symlinks (node_modules has many)."""
    total = 0
    for root, _dirs, files in os.walk(path, followlinks=False):
        for name in files:
            try:
                total += os.lstat(os.path.join(root, name)).st_size
            except OSError:
                pass
    return total


def _size_from_name(name):
    """Byte size encoded in a pool entry name, or None (legacy/pending)."""
    parts = name.split("_")
    if len(parts) == 5 and parts[4].isdigit():
        return int(parts[4])
    return None


def _measure_size(pool, h, this_path):
    """Reuse a same-hash entry's size (identical lockfile => identical tree),
    else walk once."""
    for other in glob.glob(os.path.join(pool, "node_modules_%s_*" % h)):
        if os.path.abspath(other) == os.path.abspath(this_path):
            continue
        s = _size_from_name(os.path.basename(other))
        if s is not None:
            return s
    return _dir_size(this_path)


def return_to_pool(nm_dir, pool, h):
    """Move a valid node_modules into the pool, encoding its byte size in the
    name. Staged so cross-volume (EXDEV) is detected before the size walk.
    Raises OSError(EXDEV) when the pool is on another volume."""
    os.makedirs(pool, exist_ok=True)
    slug = secrets.token_hex(4)
    pending = os.path.join(pool, "node_modules_%s_%s_pending" % (h, slug))
    os.rename(nm_dir, pending)  # cross-volume fails here, before any walk
    size = _measure_size(pool, h, pending)
    dest = os.path.join(pool, "node_modules_%s_%s_%d" % (h, slug, size))
    os.rename(pending, dest)
    now = time.time()
    os.utime(dest, (now, now))
    return dest


# ---------------------------------------------------------------------------
# commands
# ---------------------------------------------------------------------------

def cmd_install(args):
    target = os.path.abspath(args.worktree or os.getcwd())
    wt = worktree_root(target)
    pool = cache_dir()

    lockfile, install_cmd = detect_lockfile(wt)
    h = lockfile_hash(lockfile)
    nm = os.path.join(wt, "node_modules")

    # Fast no-op: real dir with matching sentinel.
    if os.path.isdir(nm) and not os.path.islink(nm):
        if read_sentinel(nm) == h:
            out("no-op (matches %s)" % h)
            return 0

    # Clear / reconcile whatever is currently at node_modules.
    if os.path.islink(nm):
        os.unlink(nm)
    elif os.path.isdir(nm):
        existing = read_sentinel(nm)
        if existing == h:
            out("no-op (matches %s)" % h)
            return 0
        if existing and existing != h:
            # Lockfile drifted under an existing install (pull/merge/bump).
            # Reconcile in place — bun/pnpm/yarn evolve incrementally; npm ci
            # reinstalls — then re-stamp. The pool is for handing whole trees
            # between worktrees, not for in-place mutation, so it stays out.
            pm = install_cmd[0]
            out("lockfile changed (%s -> %s) -> %s install in place"
                % (existing, h, pm))
            run_install(wt, install_cmd, h)
            write_sentinel(nm, h)
            return 0
        # Dirty / no sentinel: discard.
        _rmtree(nm)
        out("removed dirty node_modules (no/!sentinel)")
    elif os.path.exists(nm):
        os.unlink(nm)  # a plain file occupying the name

    # Claim from the pool: atomic rename + retry on race.
    candidates = sorted(glob.glob(os.path.join(pool, "node_modules_%s_*" % h)))
    for cand in candidates:
        try:
            os.rename(cand, nm)
        except FileNotFoundError:
            continue  # another worktree grabbed it; try next
        except OSError as e:
            if e.errno == errno.EXDEV:
                eprint("warn: pool (%s) is on a different volume than the "
                       "worktree; set NMPOOL_CACHE_DIR to a path on this volume "
                       "to enable pooling. Falling back to install." % pool)
                break
            raise
        # claimed — verify identity
        if read_sentinel(nm) == h:
            out("pool hit (mv %s)" % os.path.basename(cand))
            return 0
        # mismatched sentinel inside a supposedly-matching entry: discard
        _rmtree(nm)

    # Pool miss (or EXDEV fallback): install in place.
    pm = install_cmd[0]
    out("pool miss -> %s install" % pm)
    run_install(wt, install_cmd, h)
    write_sentinel(nm, h)
    out("installed + sentinel written (%s)" % h)
    return 0


def cmd_uninstall(args):
    target = os.path.abspath(args.worktree or os.getcwd())
    wt = worktree_root(target)
    pool = cache_dir()
    nm = os.path.join(wt, "node_modules")

    if os.path.islink(nm):
        os.unlink(nm)
        out("removed symlink (not pooled)")
    elif os.path.isdir(nm):
        sentinel = read_sentinel(nm)
        h_ok = None
        # Validate sentinel against the worktree's current lockfile when present.
        try:
            lockfile, _ = detect_lockfile(wt)
            h_ok = lockfile_hash(lockfile)
        except RuntimeError:
            h_ok = None
        if sentinel and (h_ok is None or sentinel == h_ok):
            try:
                dest = return_to_pool(nm, pool, sentinel)
                out("returned to pool (%s)" % os.path.basename(dest))
            except OSError as e:
                if e.errno == errno.EXDEV:
                    eprint("warn: pool (%s) is on a different volume than the "
                           "worktree; set NMPOOL_CACHE_DIR to a path on this "
                           "volume to enable pooling." % pool)
                    _rmtree(nm)
                    out("removed node_modules (cross-volume, not pooled)")
                else:
                    raise
        else:
            _rmtree(nm)
            out("removed dirty/mismatched node_modules (not pooled)")
    else:
        out("no-op (no node_modules)")

    _gc(pool)
    return 0


def _gc(pool):
    if not os.path.isdir(pool):
        return 0
    budget = max_cache_bytes()
    entries = []  # (mtime, path, size)
    evicted_dirty = 0
    for name in os.listdir(pool):
        p = os.path.join(pool, name)
        if not os.path.isdir(p) or not name.startswith("node_modules_"):
            continue
        # Expected name: node_modules_<hash>_<slug>_<bytes>
        parts = name.split("_")
        expected_hash = parts[2] if len(parts) >= 4 else None
        sentinel = read_sentinel(p)
        if not sentinel or (expected_hash and sentinel != expected_hash):
            _rmtree(p)
            evicted_dirty += 1
            continue
        size = _size_from_name(name)
        if size is None:
            # Legacy/pending entry: walk once, then rename forward to cache it.
            size = _dir_size(p)
            if expected_hash and len(parts) >= 4:
                fwd = os.path.join(
                    pool, "node_modules_%s_%s_%d" % (expected_hash, parts[3], size)
                )
                try:
                    os.rename(p, fwd)
                    p = fwd
                except OSError:
                    pass
        try:
            mtime = os.path.getmtime(p)
        except OSError:
            mtime = 0
        entries.append((mtime, p, size))

    total = sum(s for _, _, s in entries)
    evicted_lru = 0
    if total > budget:
        entries.sort()  # oldest first
        for _mtime, p, size in entries:
            if total <= budget:
                break
            _rmtree(p)
            total -= size
            evicted_lru += 1

    if evicted_dirty or evicted_lru:
        out("gc: evicted %d LRU, pruned %d dirty (budget %d bytes)"
            % (evicted_lru, evicted_dirty, budget))
    return 0


def cmd_gc(args):
    # The pool is global; gc needs no worktree.
    return _gc(cache_dir())


# ---------------------------------------------------------------------------
# entrypoint
# ---------------------------------------------------------------------------

def build_parser():
    p = argparse.ArgumentParser(
        prog="nmpool",
        description=(
            "Pool git-worktree node_modules directories. Worktrees get a real "
            "node_modules (no symlink) via O(1) atomic moves keyed by lockfile "
            "hash, instead of re-installing per worktree."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Pool: a single global dir (default $XDG_CACHE_HOME/nmpool), keyed\n"
            "by sha256(lockfile)[:16]. Lockfile priority: bun.lock > bun.lockb >\n"
            "pnpm-lock.yaml > package-lock.json > yarn.lock.\n\n"
            "Config (env > $XDG_CONFIG_HOME/nmpool/config.json > default):\n"
            "  NMPOOL_CACHE_DIR   pool location\n"
            "  NMPOOL_MAX_BYTES   total-bytes budget (default %d = 25 GiB)\n\n"
            "Commands:\n"
            "  install    provision node_modules (pool hit via mv, else install)\n"
            "  uninstall  return node_modules to the pool (then gc)\n"
            "  gc         evict LRU beyond the byte budget + prune dirty entries\n"
            % DEFAULT_MAX_BYTES
        ),
    )
    sub = p.add_subparsers(dest="command", required=True)

    pi = sub.add_parser("install", help="provision node_modules (idempotent)")
    pi.add_argument("--worktree", help="worktree path (default: cwd)")
    pi.set_defaults(func=cmd_install)

    pu = sub.add_parser("uninstall", help="return node_modules to the pool")
    pu.add_argument("--worktree", help="worktree path (default: cwd)")
    pu.set_defaults(func=cmd_uninstall)

    pg = sub.add_parser("gc", help="evict LRU beyond the byte budget + prune dirty")
    pg.set_defaults(func=cmd_gc)

    return p


def main(argv=None):
    args = build_parser().parse_args(argv)
    try:
        return args.func(args) or 0
    except Exception as e:  # noqa: BLE001 — top-level: report + nonzero exit
        eprint("nmpool: error: %s" % e)
        return 1


if __name__ == "__main__":
    sys.exit(main())
